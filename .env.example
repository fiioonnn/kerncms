# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  kern CMS — Environment Variables                                          ║
# ║                                                                            ║
# ║  Copy this file to .env and fill in your values:                           ║
# ║  $ cp .env.example .env                                                    ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ── App ──────────────────────────────────────────────────────────────────────

# Public URL of your app (used for OAuth callbacks, invite links, emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ── Auth ─────────────────────────────────────────────────────────────────────

# Random secret for signing sessions & tokens (min 32 chars)
# Generate one:  openssl rand -base64 32
BETTER_AUTH_SECRET=

# Must match NEXT_PUBLIC_APP_URL — used internally by Better Auth
BETTER_AUTH_URL=http://localhost:3000


# ── OAuth Providers ──────────────────────────────────────────────────────────

# Google  —  https://console.cloud.google.com/apis/credentials
# Callback URL:  {NEXT_PUBLIC_APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub  —  https://github.com/settings/developers
# Callback URL:  {NEXT_PUBLIC_APP_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=



# ── Encryption ───────────────────────────────────────────────────────────────

# 32-byte hex key for encrypting API keys at rest
# Generate one:  openssl rand -hex 32
CRYPTO_KEY=


# ── Setup ────────────────────────────────────────────────────────────────────

# 6-digit PIN shown on first launch to create the initial admin account
# Change this before deploying!
SETUP_PIN=123456


# ── Emails ────────────────────────────────────────────────────────────────────

# To send emails (e.g. for passwordless login), set up an SMTP server and add its connection string here.
RESEND_API_KEY=..
